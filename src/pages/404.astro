---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
  frontmatter={{
    title: 'Page Not Found',
    description: 'The page you are looking for does not exist.',
    template: 'splash',
    hero: {
      tagline: 'Looking for something?',
    },
  }}
>
  <div style="text-align: center; padding: 2rem 0;">
    <p style="font-size: 1.1rem; margin-bottom: 1.5rem;">
      The page you're looking for doesn't exist or may have been moved.
    </p>
    <p style="margin-bottom: 2rem;">
      If the site is being updated, try again in a minute.
    </p>
    <a
      href="/"
      style="display: inline-block; background: var(--tep-yellow); color: var(--tep-dark-deep); padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 600; text-decoration: none;"
    >
      Return Home
    </a>
  </div>
</StarlightPage>
