---
// Reusable Discord widget embed
// Usage: <DiscordWidget />
---
<div class="discord-widget">
  <iframe
    src="https://discord.com/widget?id=633351482128728064&theme=dark"
    width="100%"
    height="500"
    allowtransparency="true"
    frameborder="0"
    sandbox="allow-popups allow-popups-to-escape-sandbox allow-same-origin allow-scripts"
    title="Tep Worlds Hub Discord"
  ></iframe>
</div>

<style>
  .discord-widget {
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(242, 242, 240, 0.08);
    max-width: 500px;
  }
  iframe { display: block; }
</style>
