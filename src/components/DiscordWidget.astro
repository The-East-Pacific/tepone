---
const { theme = 'dark' } = Astro.props;
---

<div class="discord-widget-wrapper">
  <iframe
    src={`https://discord.com/widget?id=633351482128728064&theme=${theme}`}
    width="350"
    height="500"
    allowtransparency="true"
    frameborder="0"
    sandbox="allow-popups allow-popups-to-escape-sandbox allow-same-origin allow-scripts"
    title="Tep Worlds Hub Discord"
  ></iframe>
</div>

<style>
  .discord-widget-wrapper {
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(242, 242, 240, 0.08);
    display: inline-block;
  }
  :global([data-theme='light']) .discord-widget-wrapper {
    border-color: rgba(0, 0, 0, 0.12);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
</style>
